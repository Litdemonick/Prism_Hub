{
  "name": "prism-hub-extensions",
  "version": "1.0.0",
  "description": "TypeScript extension SDK y build tooling para PrismHub",
  "private": true,
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:all": "node scripts/build.mjs --all",
    "lint": "eslint extensions/**/*.ts",
    "typecheck": "tsc --noEmit",
    "new": "node scripts/new-extension.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  }
}
